```
# ── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_server_id_here

# ── Channel / Role IDs ───────────────────────────────────
TICKET_CATEGORY_ID=your_ticket_category_id_here
PREMIUM_ROLE_ID=your_premium_role_id_here
PAST_DUE_ROLE_ID=your_past_due_role_id_here

# ── Whop ─────────────────────────────────────────────────
WHOP_WEBHOOK_SECRET=your_whop_webhook_secret_here

# ── Staff role name (exact Discord role name) ────────────
STAFF_ROLE_NAME=Owner

# ── Server port (Railway sets this automatically) ────────
PORT=8080
```
